-- KumoMTA init.lua - gcp-mailnode 生成
-- FQDN={FQDN} DOMAIN={DOMAIN} SELECTOR={SELECTOR} EGRESS_SOURCE_IP={BIND_IP}
--
-- 若启动失败请核对 API（不同版本字段可能差异）：
--   * tls_mode vs tls（465 SMTPS）
--   * relay_hosts vs relay_hosts_allowed
--   * smtp_server_auth_plain 事件名在个别版本为 smtp_server_authentication
--   * get_queue_config 回调签名

local kumo = require 'kumo'

kumo.on('init', function()
  -- v0.1.82：max_segment_duration='5min' 让低流量 VPS 也能定期产出已 close 的可读归档。
  -- 默认值是无限（max_file_size=1GB 才 roll），低流量场景几天都不 roll，导致软件提取/状态页"扫描 0 个日志"。
  -- KumoMTA active segment 在 roll/close 前不可读（zstd 流式写入）；只有 close 后的归档能 zstd -dcq。
  -- 官方文档：https://docs.kumomta.com/reference/kumo/configure_local_logs/max_segment_duration/
  kumo.configure_local_logs {
    log_dir = '/var/log/kumomta',
    max_segment_duration = '5 minutes',
  }

  kumo.define_spool { name = 'data', path = '/var/spool/kumomta/data' }
  kumo.define_spool { name = 'meta', path = '/var/spool/kumomta/meta' }

  -- 接收端口（本机中继）：显式 0.0.0.0 绑所有接口，避免只绑 loopback
  kumo.start_esmtp_listener {
    listen = '0.0.0.0:25',
    hostname = '{FQDN}',
    relay_hosts = { '127.0.0.1', '::1' },
    max_recipients_per_message = 100,
    trace_headers = {
      received_header = {TRACE_RECEIVED},
      supplemental_header = {TRACE_SUPPLEMENTAL},
    },
  }

  -- Submission 587（STARTTLS + AUTH 必需）
  -- 不写 relay_hosts：空 `{}` 在 Lua→JSON 序列化时会被解析成 map（report: "expected a sequence"），
  -- 直接省略让 KumoMTA 走"AUTH 通过才允许中继"的默认逻辑。
  kumo.start_esmtp_listener {
    listen = '0.0.0.0:587',
    hostname = '{FQDN}',
    tls_certificate = '/opt/kumomta/etc/tls/cert.pem',
    tls_private_key = '/opt/kumomta/etc/tls/key.pem',
    trace_headers = {
      received_header = {TRACE_RECEIVED},
      supplemental_header = {TRACE_SUPPLEMENTAL},
    },
  }

  -- 注：KumoMTA 2026.03+ 的 start_esmtp_listener 移除了 tls_mode='Implicit' 字段，
  -- 原生不支持 465 implicit TLS。客户端（brutal-mailer / 邮件大师）请用 587 + STARTTLS。
  -- 如坚持要 465，可在前面加 haproxy/nginx stream SNI terminator，此处不做。
end)

-- v0.1.57 占位符：单 NIC 时是标准 source/pool；多 NIC 时是 8 source 随机轮换块
{SOURCES_BLOCK}

-- v0.1.85：取消所有 egress path shaping。不注册 get_egress_path_config，
-- 让 KumoMTA 走内部默认（connection_limit 默认 10，无显式速率上限，
-- 遇 421/throttle 由 KumoMTA 自适应退避）。

local auth = require 'smtp_auth'
kumo.on('smtp_server_auth_plain', auth.check)

-- v0.1.73 黑洞收件：
-- 25 端口 inbound = AUTH 未通过 → accept_to=true（catch-all 收信）+ relay_to=false（不转发）
-- 587 端口 submission = AUTH 通过 → relay_to=true（出站发信）
-- 这样 MX 探测器扫描看到能收信（提升域名信誉），但绝不变成开放中继。
kumo.on('get_listener_domain', function(domain, listener, conn_meta)
  local authn = conn_meta:get_meta('authn_id')
  if authn and authn ~= '' then
    -- AUTH 通过：587 出站发信
    return kumo.make_listener_domain { relay_to = true }
  end
  -- 未 AUTH：25 inbound 黑洞，作为任意域的最终目的地接收（accept_to），但不转发（relay_to）
  return kumo.make_listener_domain { accept_to = true, relay_to = false }
end)

kumo.on('smtp_server_message_received', function(msg)
  -- v0.1.73：判断是出站还是 inbound 黑洞
  local authn = msg:get_meta('authn_id') or ''
  if authn == '' then
    -- inbound 黑洞：直接送进 null queue，1 秒过期自动消失，不签 DKIM/ARC（避免给垃圾邮件背书）
    msg:set_meta('queue', 'null.blackhole')
    return
  end

  -- 出站路径（AUTH 通过）：原有 DKIM + ARC 签名逻辑
  -- KumoMTA 作为透明中继：Persona 伪造（Received 链 / UA / X-Mailer）完全在
  -- brutal-mailer 侧完成，这里只负责"屏蔽客户端真实 IP"兜底。
  -- DKIM 签名：v0.1.74 加 List-Unsubscribe / List-Unsubscribe-Post（Google 一键退订要求这两个头进 DKIM h= 列表）
  local signer = kumo.dkim.rsa_sha256_signer {
    domain = '{DOMAIN}',
    selector = '{SELECTOR}',
    headers = { 'From', 'To', 'Subject', 'Date', 'Message-ID', 'List-Id', 'List-Unsubscribe', 'List-Unsubscribe-Post' },
    key = '/opt/kumomta/etc/keys/{DOMAIN}/{SELECTOR}.key',
  }
  msg:dkim_sign(signer)

  -- ARC seal: 复用同一把 RSA 密钥
  msg:arc_seal(signer, '{FQDN}', {})
end)

kumo.on('get_queue_config', function(domain, tenant, campaign)
  if domain == 'null.blackhole' then
    -- 黑洞 queue：1 秒过期，不重试，不投递
    return kumo.make_queue_config {
      max_age = '1s',
      retry_interval = '1s',
      max_retry_interval = '1s',
    }
  end
  return kumo.make_queue_config {
    egress_pool = 'default',
  }
end)
