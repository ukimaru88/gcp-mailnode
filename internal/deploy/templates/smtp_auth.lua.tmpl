-- SMTP AUTH 验证模块 - PLAIN 明文比对
-- KumoMTA 2026.03+ 回调签名: (authz, authc, password, conn_meta)
--   authz = authorization identity (通常为空)
--   authc = authentication identity (用户名)
--   password = 密码
-- TODO: 后续改 bcrypt/argon2 哈希

local M = {}

local USERNAME = '{USERNAME}'
local PASSWORD = '{PASSWORD}'

function M.check(authz, authc, password, conn_meta)
  if authc == USERNAME and password == PASSWORD then
    return true
  end
  return false
end

return M
